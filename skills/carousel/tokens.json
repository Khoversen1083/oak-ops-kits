{
  "name": "@kevhov.ai IG Carousel System",
  "description": "Single-preset design system for 1080x1350 Instagram carousel slideshows. Obsidian/indigo brand spec, magazine-style structure, viral 8-slide arc.",
  "preset": {
    "obsidian": {
      "use_for": "All IG feed carousels for @kevhov.ai (AI builder content, system reveals, step-by-step playbooks).",
      "template_base": "slide-magazine.html",
      "colors": {
        "bg": "#0A0A0F",
        "surface": "#14141F",
        "surface_alt": "#1B1B2A",
        "ink": "#F0F0F5",
        "ink_soft": "#A1A1B5",
        "ink_dim": "#5E5E78",
        "rule": "#2A2A3F",
        "accent": "#6366F1",
        "accent_glow": "#8B5CF6",
        "accent_dim": "#3F3D9E"
      },
      "typography": {
        "display": "'Inter', sans-serif",
        "display_weight": 900,
        "body": "'Inter', sans-serif",
        "body_weight": 500,
        "mono": "'JetBrains Mono', monospace"
      }
    }
  },
  "output": {
    "default_location": "~/Library/Mobile Documents/com~apple~CloudDocs/@kevhov.ai/00-Post Today/",
    "subfolder_pattern": "{reel-folder-or-keyword}/carousel/",
    "filename_pattern": "{NN}.jpg",
    "format": "jpg",
    "format_options": 92,
    "never_write_to": ["~/Desktop"]
  },
  "slide": {
    "width": 1080,
    "height": 1350,
    "device_scale_factor": 2,
    "viewport_units": "px"
  },
  "arc": {
    "total_slides": 8,
    "slots": [
      {"n": 1, "type": "hook",    "rule": "5-8 word headline. Pattern interrupt. Curiosity gap. No CTA, no signature."},
      {"n": 2, "type": "stakes",  "rule": "One sentence under 12 words. Frame the cost of NOT having this."},
      {"n": 3, "type": "system",  "rule": "Name the system. One-liner architecture."},
      {"n": 4, "type": "step",    "rule": "Step 01. Concrete beat."},
      {"n": 5, "type": "step",    "rule": "Step 02. Concrete beat."},
      {"n": 6, "type": "step",    "rule": "Step 03. Concrete beat."},
      {"n": 7, "type": "payoff",  "rule": "Specific outcome. What changes once the system runs."},
      {"n": 8, "type": "cta",     "rule": "Comment KEYWORD + @kevhov.ai signature."}
    ]
  }
}
